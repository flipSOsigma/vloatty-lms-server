generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider  = "postgresql"
}

model User {
  id               String            @id @default(uuid())
  name             String
  email            String            @unique
  password         String?
  premiumStatus    String            @default("free")
  institution      String
  avatar           String
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  createdSubjects  Subject[]         @relation("SubjectCreator")
  lecturedSubjects SubjectLecturer[]
  participatedSubjects SubjectParticipant[]
  institutionId     String?
  linkedInstitution Institution?      @relation(fields: [institutionId], references: [id], onDelete: SetNull)
  institutionRole   String?
  memberships       InstitutionMember[]
  uploadedFiles     InstitutionFile[] @relation("FileUploader")
}

model Subject {
  id           String               @id @default(uuid())
  name         String
  room         String?
  color        String?
  thumbnail    String?
  description  String?              @db.Text
  isOpen       Boolean              @default(false)
  category     String               @default("Lecture")
  creatorId    String
  creator      User                 @relation("SubjectCreator", fields: [creatorId], references: [id])
  deletedBy    String?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  deletedAt    DateTime?
  lecturers    SubjectLecturer[]
  schedules    SubjectSchedule[]
  modules      Module[]
  events       LmsEvent[]
  participants SubjectParticipant[]
  institutionId    String?
  institution      Institution?      @relation(fields: [institutionId], references: [id], onDelete: SetNull)
}

model SubjectLecturer {
  subjectId String
  subject   Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([subjectId, userId])
}

model SubjectSchedule {
  id        String   @id @default(uuid())
  day       String
  startTime String
  endTime   String
  room      String?
  subjectId String
  subject   Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
}

model Module {
  id        String    @id @default(uuid())
  title     String
  desc      String            @db.Text
  date      DateTime
  subjectId String
  subject   Subject   @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  lessons   Lesson[]
}

model Lesson {
  id           String    @id @default(uuid())
  title        String
  desc         String    @db.Text
  type         String    @default("learning")
  homeworkFile String?
  openDate     DateTime
  closeDate    DateTime
  closeType    String    @default("open")
  moduleId     String
  module       Module    @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?
}

model LmsEvent {
  id                   String    @id @default(uuid())
  title                String
  subtitle             String?
  timeStart            String
  timeEnd              String
  dayIndex             Int
  color                String
  tagText              String?
  tagType              String?
  linkText             String?
  linkUrl              String?
  participantsInitials String?
  participantsCount    Int?
  status               String?
  description          String?   @db.Text
  image                String?
  subjectId            String?
  subject              Subject?  @relation(fields: [subjectId], references: [id], onDelete: SetNull)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  deletedAt            DateTime?
}

model SubjectParticipant {
  subjectId String
  subject   Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@id([subjectId, userId])
}

model Institution {
  id                 String              @id @default(uuid())
  name               String
  description        String?             @db.Text
  subscriptionStatus String              @default("free")
  thumbnail          String?
  inviteCode         String?             @unique
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  deletedAt          DateTime?
  users              User[]
  subjects           Subject[]
  members            InstitutionMember[]
  files              InstitutionFile[]
}

model InstitutionMember {
  id            String      @id @default(uuid())
  institutionId String
  institution   Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  role          String      @default("lecturer")
  joinedAt      DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([institutionId, userId])
}

model InstitutionFile {
  id            String      @id @default(uuid())
  name          String
  url           String
  mimeType      String
  sizeBytes     Int
  category      String      @default("General")
  uploadedById  String
  uploadedBy    User        @relation("FileUploader", fields: [uploadedById], references: [id])
  institutionId String
  institution   Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  deletedAt     DateTime?
}
